# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Vagrantfile — Cluster Kubernetes 1.34
# 1 controlplane + N nodes, tous provisionnés par install_kubernetes.sh
#
# Prérequis : VirtualBox + Vagrant installés sur la machine hôte
#
# Commandes essentielles :
#   vagrant up                                                → créer les VMs ET installer K8s (tout en un)
#   vagrant up --no-provision                                 → créer les VMs seulement
#   vagrant provision                                         → relancer l'installation sur toutes les VMs
#   vagrant provision controlplane                            → relancer l'installation sur le master uniquement
#   vagrant ssh controlplane                                  → se connecter au master
#   vagrant ssh node1                                         → se connecter au worker
#   vagrant plugin install vagrant-vbguest                    → Installation du plugin pour les Snapshots
#   vagrant snapshot save <snapshot_name>                     → sauvegarder l'état de toutes les VMs
#   vagrant snapshot save <vm_name> <snapshot_name>           → sauvegarder l'état d'une VM
#   vagrant halt                                              → arrêter les VMs
#   vagrant destroy -f                                        → supprimer toutes les VMs

Vagrant.configure("2") do |config|

  # ── Image de base ────────────────────────────────────────────────────────────
  config.vm.box         = "eazytraining/ubuntu2204"
  config.vm.box_version = "1.0"
  # config.vm.box = "ubuntu/jammy64"
  # Désactiver la vérification auto de mises à jour de la box (accélère vagrant up)
  config.vm.box_check_update = false

  # ── Controlplane ─────────────────────────────────────────────────────────────
  # IMPORTANT : le controlplane doit être défini EN PREMIER dans le Vagrantfile.
  # Vagrant provisionnera les VMs dans l'ordre de définition, ce qui garantit
  # que le master génère le fichier join_command.sh avant que les workers ne le cherchent.
  config.vm.define "controlplane" do |cp|
    cp.vm.hostname = "controlplane"
    cp.vm.network "private_network", type: "static", ip: "192.168.90.10"

    cp.vm.provider "virtualbox" do |vb|
      vb.name   = "controlplane"
      vb.memory = 4096
      vb.cpus   = 2
      # Désactiver les périphériques inutiles pour alléger la VM
      vb.customize ["modifyvm", :id, "--audio",   "none"]
      vb.customize ["modifyvm", :id, "--usb",     "off"]
      # Activer les VirtualBox Guest Additions (nécessaire pour le dossier /vagrant partagé)
      vb.customize ["modifyvm", :id, "--clipboard", "disabled"]
    end

    cp.vm.provision "shell" do |s|
      s.path       = "install_kubernetes.sh"   # chemin relatif au Vagrantfile
      s.privileged = true                       # exécuté en root (requis par apt, kubeadm...)
    end
  end

  # ── Worker nodes ─────────────────────────────────────────────────────────────
  # Modifier 'nodes' pour ajouter des workers supplémentaires (node1, node2, ...)
  nodes    = 1
  ram_node = 3072
  cpu_node = 2

  (1..nodes).each do |i|
    config.vm.define "node#{i}" do |node|
      node.vm.hostname = "node#{i}"
      node.vm.network "private_network", type: "static", ip: "192.168.90.1#{i}"

      node.vm.provider "virtualbox" do |vb|
        vb.name   = "node#{i}"
        vb.memory = ram_node
        vb.cpus   = cpu_node
        vb.customize ["modifyvm", :id, "--audio", "none"]
        vb.customize ["modifyvm", :id, "--usb",   "off"]
      end

      # Même script — le hostname permet la détection automatique du rôle
      node.vm.provision "shell" do |s|
        s.path       = "install_kubernetes.sh"
        s.privileged = true
      end
    end
  end

end
